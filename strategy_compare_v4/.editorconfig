# ============================================================
# Institutional Strategy Comparison Platform V4
# .editorconfig
# ============================================================

root = true

# ------------------------------------------------------------
# Default Settings
# ------------------------------------------------------------

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

indent_style = space
indent_size = 4

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------

[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# ------------------------------------------------------------
# Markdown
# ------------------------------------------------------------

[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ------------------------------------------------------------
# YAML
# ------------------------------------------------------------

[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ------------------------------------------------------------
# JSON
# ------------------------------------------------------------

[*.json]
indent_style = space
indent_size = 2

# ------------------------------------------------------------
# TOML
# ------------------------------------------------------------

[*.toml]
indent_style = space
indent_size = 4

# ------------------------------------------------------------
# Shell Scripts
# ------------------------------------------------------------

[*.sh]
indent_style = space
indent_size = 4

# ------------------------------------------------------------
# Windows Batch
# ------------------------------------------------------------

[*.bat]
indent_style = space
indent_size = 4

# ------------------------------------------------------------
# CSV Files
# ------------------------------------------------------------

[*.csv]
charset = utf-8

# ------------------------------------------------------------
# Excel Files
# ------------------------------------------------------------

[*.xlsx]
insert_final_newline = false

# ------------------------------------------------------------
# Images
# ------------------------------------------------------------

[*.{png,jpg,jpeg,svg,gif}]
insert_final_newline = false
trim_trailing_whitespace = false

# ------------------------------------------------------------
# GitHub Workflows
# ------------------------------------------------------------

[.github/workflows/*]
indent_style = space
indent_size = 2

# ------------------------------------------------------------
# VS Code Settings
# ------------------------------------------------------------

[.vscode/settings.json]
indent_style = space
indent_size = 2
